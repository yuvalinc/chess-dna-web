{
  "manifest_version": 3,
  "name": "Chess DNA — Reddit Co-pilot",
  "version": "0.1.0",
  "description": "One-click posting, karma sync, and reply detection for the Chess DNA Reddit campaign.",

  "permissions": ["storage", "alarms", "notifications"],

  "host_permissions": [
    "https://www.reddit.com/*",
    "https://api.github.com/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Chess DNA Reddit Co-pilot",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://www.reddit.com/r/*/comments/*"],
      "js": ["content/reddit-thread.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
